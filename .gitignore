.coverage.*
.hypothesis/
.mypy_cache/
.nox/
.pytest_cache/
.pyre/
.pytype/
.ruff_cache/
.tox/
htmlcov/

# Local environment files
.env
.env.*
!.env.example
.python-version

# Editors and OS files
.idea/
.vscode/
.claude/
.DS_Store
Thumbs.db

